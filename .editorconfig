root = true

[*.cs]
# Braces are mandatory on if/else/for/foreach/while/etc.
csharp_prefer_braces = true
dotnet_diagnostic.IDE0011.severity = error

# No unnecessary usings.
dotnet_diagnostic.IDE0005.severity = error

# Fields that are never reassigned must be readonly.
dotnet_style_readonly_field = true
dotnet_diagnostic.IDE0044.severity = error

# No unused value assignments or unused parameters.
dotnet_diagnostic.IDE0059.severity = error
dotnet_diagnostic.IDE0060.severity = error

# Prefer switch expressions over switch statements.
csharp_style_prefer_switch_expression = true
dotnet_diagnostic.IDE0066.severity = error

# Prefer collection expressions ([]) - except IDE0305, which would rewrite
# fluent .ToArray()/.ToList() calls into [.. x] spreads.
dotnet_style_prefer_collection_expression = when_types_loosely_match
dotnet_diagnostic.IDE0300.severity = error
dotnet_diagnostic.IDE0301.severity = error
dotnet_diagnostic.IDE0302.severity = error
dotnet_diagnostic.IDE0303.severity = error
dotnet_diagnostic.IDE0304.severity = error
dotnet_diagnostic.IDE0305.severity = none
