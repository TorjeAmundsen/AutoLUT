<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AutoLUT.App.ViewModels"
    x:Class="AutoLUT.App.Views.MainView"
    x:DataType="vm:MainWindowViewModel"
    Background="#2C2C2C"
>

  <Panel>

    <Grid ColumnDefinitions="300,*" RowDefinitions="*,Auto">

      <!-- Screenshot list -->
      <Grid Grid.Column="0" Grid.Row="0" RowDefinitions="Auto,*">
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="12,12,12,8">
          <Button Content="Add Screenshots..." Command="{Binding AddScreenshotsCommand}" />
          <Button Content="Reset" Command="{Binding ResetCommand}" />
        </StackPanel>
        <ListBox Grid.Row="1" Margin="12,0,12,12" ItemsSource="{Binding Screenshots}" SelectedItem="{Binding SelectedScreenshot}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:ScreenshotItemViewModel">
              <Grid ColumnDefinitions="Auto,*">
                <Border
                    Grid.Column="0"
                    Width="16"
                    Height="16"
                    Margin="0,2,8,0"
                    VerticalAlignment="Top"
                    CornerRadius="3"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Background="{Binding SwatchBrush}"
                    IsVisible="{Binding SwatchBrush, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                  <TextBlock Foreground="{Binding StatusBrush}" FontSize="11" TextWrapping="Wrap"><Run Text="{Binding StatusPrefix}" /><Run Text="{Binding StatusHex}" FontFamily="Consolas,Menlo,DejaVu Sans Mono,monospace" /><Run Text="{Binding StatusSuffix}" /></TextBlock>
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

      <!-- Preview -->
      <Border Grid.Column="1" Grid.Row="0" Background="#151515" BorderBrush="#484848" BorderThickness="1" Margin="0,12,12,12" CornerRadius="4">
        <Panel>
          <TextBlock Text="No screenshot selected" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding PreviewImage, Converter={x:Static ObjectConverters.IsNull}}" />
          <Image Source="{Binding PreviewImage}" Stretch="Uniform" Margin="8" />
        </Panel>
      </Border>

      <!-- Bottom bar: controls + status -->
      <DockPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="12,0,12,12" LastChildFill="True">
        <CheckBox DockPanel.Dock="Left" Content="Show Corrected Image" IsChecked="{Binding ShowCorrected}" IsEnabled="{Binding HasLut}" VerticalAlignment="Center" />
        <Button DockPanel.Dock="Left" Content="Generate LUT" Command="{Binding GenerateCommand}" Margin="16,0,0,0" />
        <Button DockPanel.Dock="Left" Content="Save LUT.png" Command="{Binding SaveLutCommand}" Margin="8,0,0,0" />
        <Button DockPanel.Dock="Right"
                Content="How to use"
                Command="{Binding OpenHelpCommand}"
                Margin="16,0,0,0" />
        <Button DockPanel.Dock="Right"
                Content="Download savestates"
                Click="OnSavestatesLinkClick"
                IsVisible="{Binding ShowSavestatesLink}"
                Margin="16,0,0,0" />
        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="16,0,0,0" TextWrapping="Wrap" />
      </DockPanel>

    </Grid>

    <!-- Help overlay -->
    <Border Background="#B0000000" IsVisible="{Binding IsHelpOpen}">
      <Border Background="#2C2C2C" BorderBrush="#565656" BorderThickness="1" CornerRadius="4" MaxWidth="560" Padding="24,20" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="10">
          <TextBlock Text="How to use AutoLUT" FontWeight="SemiBold" FontSize="16" />
          <TextBlock TextWrapping="Wrap" Text="{Binding HelpSavestatesStep}" />
          <TextBlock TextWrapping="Wrap" Text="2. Load each savestate in gz and screenshot the solid color it displays - 39 colors, any order, any filenames. Screenshot the raw capture source: in OBS, right-click the source and use Screenshot (Source) with no filters." />
          <TextBlock TextWrapping="Wrap" Text="3. Click Add Screenshots and select all your captures, then Generate LUT." />
          <TextBlock TextWrapping="Wrap" Text="4. Check the result with Show Corrected Image - the preview matches exactly what OBS will render." />
          <TextBlock TextWrapping="Wrap" Text="5. Save LUT.png, then in OBS: right-click your capture source, Filters, add Apply LUT, and select the file." />
          <TextBlock TextWrapping="Wrap" Foreground="#999999" Text="All 9 gray savestates (including black and white) are required; at least 20 of the 39 colors must be identified. The game HUD in the screenshots is fine - just keep the center of the screen clear." />
          <DockPanel LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="Full instructions on GitHub" Click="OnReadmeLinkClick" />
            <Button DockPanel.Dock="Right" Content="Close" MinWidth="72" HorizontalContentAlignment="Center" Command="{Binding CloseHelpCommand}" />
          </DockPanel>
        </StackPanel>
      </Border>
    </Border>

    <!-- Modal warning overlay (used in the browser, where dialog Windows are unavailable) -->
    <Border Background="#B0000000" IsVisible="{Binding Overlay.IsOpen, FallbackValue=False}">
      <Border Background="#2C2C2C" BorderBrush="#565656" BorderThickness="1" CornerRadius="4" MaxWidth="420" Padding="20,16" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="{Binding Overlay.Title}" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Overlay.Message}" TextWrapping="Wrap" MaxWidth="380" />
          <Button Content="OK" MinWidth="72" HorizontalAlignment="Right" HorizontalContentAlignment="Center" Command="{Binding Overlay.DismissCommand}" />
        </StackPanel>
      </Border>
    </Border>

  </Panel>

</UserControl>
