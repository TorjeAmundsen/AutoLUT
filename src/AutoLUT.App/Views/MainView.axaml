<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AutoLUT.App.ViewModels"
    x:Class="AutoLUT.App.Views.MainView"
    x:DataType="vm:MainWindowViewModel"
    Background="#2C2C2C"
>

  <UserControl.Resources>
    <x:String x:Key="DeltaEExplanation">dE (delta E) is the color difference between the capture AFTER correction by this LUT and its target - it measures how well the correction lands, not how far off the raw capture was. Measured in the Oklab perceptual color space: 0 means identical, below roughly 0.0050 the difference is invisible even in flat colors side by side, around 0.0100 it is noticeable side-by-side, and 1.0 is about the distance from black to white.</x:String>
    <!-- Palette-check tile: captured / corrected / target stacked top to bottom.
         Tiles stretch to fill their UniformGrid cell and stay square: height tracks the
         arranged width, and the three stripes split it via star rows. -->
    <DataTemplate x:Key="SwatchTileTemplate" x:DataType="vm:CalibrationDetailsViewModel+SwatchTile">
      <Border Background="Transparent" BorderBrush="{Binding TileBorderBrush}"
              BorderThickness="1" CornerRadius="3"
              Margin="2" ClipToBounds="True"
              Height="{Binding $self.Bounds.Width}">
        <!-- Monospace so the padded hex columns line up -->
        <ToolTip.Tip>
          <TextBlock Text="{Binding Tooltip}" FontFamily="Consolas,Menlo,DejaVu Sans Mono,monospace" />
        </ToolTip.Tip>
        <!-- Hovering a single stripe outlines it and names it. Stripes carry no border at
             rest - even a transparent border insets the background and reads as a seam -
             so the colors sit flush against each other; the outline only exists while
             hovered. The label's drop shadow keeps white text readable on light stripes.
             The selectors anchor on the stripe class because :pointerover also sets on
             every ancestor while the pointer is inside it. -->
        <Border.Styles>
          <Style Selector="Border.stripe">
            <Setter Property="BorderThickness" Value="0" />
          </Style>
          <Style Selector="Border.stripe:pointerover">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="White" />
          </Style>
          <Style Selector="Border.stripe > TextBlock">
            <Setter Property="IsVisible" Value="False" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Effect" Value="drop-shadow(0 1 4 #FF000000)" />
          </Style>
          <Style Selector="Border.stripe:pointerover > TextBlock">
            <Setter Property="IsVisible" Value="True" />
          </Style>
        </Border.Styles>
        <!-- ClipToBounds clips to the rect, not the corner radius, so the top and bottom
             stripes round their outer corners themselves (outer radius 3 - 1px border = 2) -->
        <Grid RowDefinitions="*,*,*">
          <Border Grid.Row="0" Classes="stripe" Background="{Binding ObservedBrush}" CornerRadius="2,2,0,0">
            <TextBlock Text="captured" />
          </Border>
          <Border Grid.Row="1" Classes="stripe" Background="{Binding CorrectedBrush}">
            <TextBlock Text="corrected" />
          </Border>
          <Border Grid.Row="2" Classes="stripe" Background="{Binding TargetBrush}" CornerRadius="0,0,2,2">
            <TextBlock Text="target" />
          </Border>
        </Grid>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <Panel>

    <Grid ColumnDefinitions="300,*" RowDefinitions="*,Auto">

      <!-- Screenshot list -->
      <Grid Grid.Column="0" Grid.Row="0" RowDefinitions="Auto,*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="*,*" ColumnSpacing="8" Margin="12,12,12,8">
          <Button Grid.Column="0" Content="Load images..." Command="{Binding AddScreenshotsCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
          <Button Grid.Column="1" Content="Reset" Command="{Binding ResetCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
        </Grid>
        <ListBox Grid.Row="1" Margin="12,0,12,8" Background="#232323" ItemsSource="{Binding Screenshots}" SelectedItem="{Binding SelectedScreenshot}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:ScreenshotItemViewModel">
              <Grid ColumnDefinitions="Auto,*">
                <Border
                    Grid.Column="0"
                    Width="16"
                    Height="16"
                    Margin="0,2,8,0"
                    VerticalAlignment="Top"
                    CornerRadius="3"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Background="{Binding SwatchBrush}"
                    IsVisible="{Binding SwatchBrush, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                  <TextBlock Foreground="{Binding StatusBrush}" FontSize="11" TextWrapping="Wrap"><Run Text="{Binding StatusPrefix}" /><Run Text="{Binding StatusHex}" FontFamily="Consolas,Menlo,DejaVu Sans Mono,monospace" /><Run Text="{Binding StatusSuffix}" /></TextBlock>
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="8" Margin="12,0,12,12">
          <Button Grid.Column="0" Content="Generate LUT" Command="{Binding GenerateCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
          <Button Grid.Column="1" Content="Save LUT.png" Command="{Binding SaveLutCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
        </Grid>
      </Grid>

      <!-- Preview pane: shows the screenshot preview, or the "How to use" guide while it is open -->
      <Border Grid.Column="1" Grid.Row="0" Background="#151515" BorderBrush="#484848" BorderThickness="1" Margin="0,12,12,12" CornerRadius="4">
        <Panel>
          <Panel IsVisible="{Binding !Help.IsOpen}">
            <TextBlock Text="No screenshot selected" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding PreviewImage, Converter={x:Static ObjectConverters.IsNull}}" />
            <Image Source="{Binding PreviewImage}" Stretch="Uniform" Margin="8" />
          </Panel>

          <!-- Guide: platform-select page, then a step-through wizard per platform.
               Also a drag-and-drop target for loading screenshots (wired in code-behind).
               Transparent background keeps the whole pane hit-testable for drops. -->
          <DockPanel x:Name="HelpGuide" DragDrop.AllowDrop="True" Background="Transparent"
                     IsVisible="{Binding Help.IsOpen}" Margin="24,20">
            <!-- Cap the content width for readability; the outer DockPanel still spans the
                 whole pane so every pixel stays a drop target. Stretch (the default) keeps
                 the width constant across steps - Center would size to each step's content. -->
            <DockPanel MaxWidth="680">
              <TextBlock DockPanel.Dock="Top" Text="How to use AutoLUT" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10" />

              <!-- Bottom row pinned to the pane: GitHub link bottom-left, step navigation bottom-right -->
              <DockPanel DockPanel.Dock="Bottom" LastChildFill="False" Margin="0,10,0,0">
                <Button DockPanel.Dock="Left" Content="Full instructions on GitHub" Click="OnReadmeLinkClick" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8"
                            IsVisible="{Binding !Help.IsPlatformPage}">
                  <Button Content="Back" MinWidth="72" HorizontalContentAlignment="Center"
                          Command="{Binding Help.BackCommand}" />
                  <Button Content="{Binding Help.NextLabel}" MinWidth="72" HorizontalContentAlignment="Center"
                          Command="{Binding Help.NextCommand}" />
                </StackPanel>
              </DockPanel>

              <!-- Step content fills the remaining space and scrolls only if it must.
                   Right margin keeps the scrollbar from covering the text. -->
              <ScrollViewer x:Name="GuideScroll">
                <StackPanel Spacing="10" Margin="0,0,16,0">

                  <!-- Page 0: platform choice -->
                  <StackPanel Spacing="10" IsVisible="{Binding Help.IsPlatformPage}">
                    <TextBlock Text="Choose your setup:" />
                    <StackPanel Spacing="8">
                      <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="12,16"
                              Command="{Binding Help.SelectPlatformCommand}" CommandParameter="wii">
                        <StackPanel Spacing="8">
                          <TextBlock Text="Wii via Homebrew app (recommended)" FontWeight="SemiBold" />
                          <TextBlock TextWrapping="Wrap" Foreground="#C8C8C8" FontSize="12"
                                     Text="You have the Wii Homebrew channel available and want a quick and easy way to scroll through the required color palette." />
                        </StackPanel>
                      </Button>
                      <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="12,16"
                              Command="{Binding Help.SelectPlatformCommand}" CommandParameter="n64">
                        <StackPanel Spacing="8">
                          <TextBlock Text="N64 via custom ROM (recommended)" FontWeight="SemiBold" />
                          <TextBlock TextWrapping="Wrap" Foreground="#C8C8C8" FontSize="12"
                                     Text="You have an N64 flashcard available and want a quick and easy way to scroll through the required color palette. This is also technically more accurate than gz on N64." />
                        </StackPanel>
                      </Button>
                      <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="12,16"
                              Command="{Binding Help.SelectPlatformCommand}" CommandParameter="gz">
                        <StackPanel Spacing="8">
                          <TextBlock Text="Ocarina of Time Practice ROM savestates (gz 0.3.7)" FontWeight="SemiBold" />
                          <TextBlock TextWrapping="Wrap" Foreground="#C8C8C8" FontSize="12"
                                     Text="You're an Ocarina of Time speedrunner and want to load the colors via gz without a custom homebrew app or custom N64 ROM aside from gz." />
                        </StackPanel>
                      </Button>
                    </StackPanel>
                  </StackPanel>

                  <!-- Revealed steps stack up below one another as the user clicks Next.
                       Each step: header + body (amber callout variant for the OBS step)
                       + per-step artifact buttons + note. -->
                  <ItemsControl ItemsSource="{Binding Help.VisibleSteps}"
                                IsVisible="{Binding !Help.IsPlatformPage}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:HelpWizardViewModel+GuideStepItem">
                        <StackPanel Spacing="8" Margin="0,0,0,12">
                          <TextBlock Text="{Binding Header}" FontWeight="SemiBold" />
                          <Border Background="#26FFB020" BorderBrush="#FFB020" BorderThickness="1" CornerRadius="4"
                                  Padding="12,10" IsVisible="{Binding IsObsSetup}">
                            <TextBlock Text="{Binding Body}" TextWrapping="Wrap" />
                          </Border>
                          <TextBlock Text="{Binding Body}" TextWrapping="Wrap"
                                     IsVisible="{Binding !IsObsSetup}" />
                          <Button Content="AutoLUT Palette (Wii app)" Click="OnWiiAppLinkClick"
                                  IsVisible="{Binding ShowWiiDownload}" />
                          <Button Content="AutoLUT Palette (N64 ROM)" Click="OnN64RomLinkClick"
                                  IsVisible="{Binding ShowN64Download}" />
                          <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowGzDownloads}">
                            <Button Content="gz 0.3.7 OoT 1.0" Tag="1.0" Click="OnSavestatesVersionClick" />
                            <Button Content="gz 0.3.7 OoT 1.1" IsEnabled="False" ToolTip.Tip="Not made yet" />
                            <Button Content="gz 0.3.7 OoT 1.2" Tag="1.2" Click="OnSavestatesVersionClick" />
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowWiiBundle}">
                            <Button Content="Copy app to clipboard" Click="OnWiiCopyClick" />
                            <Button Content="Open folder" Tag="wii" Click="OnBundleFolderClick" />
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowN64Bundle}">
                            <Button Content="Copy ROM to clipboard" Click="OnN64CopyClick" />
                            <Button Content="Open folder" Tag="n64" Click="OnBundleFolderClick" />
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowGzBundle}">
                            <Button Content="Copy 1.0 savestates" Tag="1.0" Click="OnGzCopyClick" />
                            <Button Content="Copy 1.2 savestates" Tag="1.2" Click="OnGzCopyClick" />
                            <Button Content="Open folder" Tag="savestates" Click="OnBundleFolderClick" />
                          </StackPanel>
                          <Button Content="Load images..." Click="OnLoadImagesClick"
                                  IsVisible="{Binding ShowLoadImages}" />
                          <TextBlock Text="{Binding Note}" TextWrapping="Wrap"
                                     IsVisible="{Binding HasPrimaryNote}" />
                          <TextBlock Text="{Binding Note}" Foreground="#999999" TextWrapping="Wrap"
                                     IsVisible="{Binding HasSubtleNote}" />
                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                </StackPanel>
              </ScrollViewer>
            </DockPanel>
          </DockPanel>
        </Panel>
      </Border>

      <!-- Bottom bar: show-corrected under the list, status aligned to the column split, actions on the right -->
      <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="300,*" Margin="0,0,12,12">
        <CheckBox Grid.Column="0" Content="Show Corrected Image" IsChecked="{Binding ShowCorrected}" IsEnabled="{Binding HasLut}" VerticalAlignment="Center" Margin="12,0,0,0" />
        <DockPanel Grid.Column="1" LastChildFill="True">
          <Button DockPanel.Dock="Right"
                  Content="{Binding Help.ToggleLabel}"
                  Command="{Binding ToggleHelpCommand}"
                  MinWidth="100"
                  HorizontalContentAlignment="Center"
                  Margin="8,0,0,0" />
          <Button DockPanel.Dock="Right"
                  Content="Check for updates"
                  Command="{Binding CheckForUpdatesCommand}"
                  IsVisible="{Binding IsDesktop}"
                  Margin="8,0,0,0" />
          <Button DockPanel.Dock="Right"
                  Content="Downloads"
                  IsVisible="{Binding ShowSavestatesLink}"
                  Margin="8,0,0,0">
            <Button.Flyout>
              <Flyout>
                <StackPanel Spacing="4" MinWidth="160">
                  <Button Content="gz 0.3.7 OoT 1.0" Tag="1.0" Click="OnSavestatesVersionClick"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                  <Button Content="gz 0.3.7 OoT 1.1" IsEnabled="False" ToolTip.Tip="Not made yet"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                  <Button Content="gz 0.3.7 OoT 1.2" Tag="1.2" Click="OnSavestatesVersionClick"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                  <Button Content="AutoLUT Palette (Wii app)" Click="OnWiiAppLinkClick"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                  <Button Content="AutoLUT Palette (N64 ROM)" Click="OnN64RomLinkClick"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                </StackPanel>
              </Flyout>
            </Button.Flyout>
          </Button>
          <Button DockPanel.Dock="Right"
                  Content="Show details"
                  Command="{Binding OpenDetailsCommand}"
                  IsVisible="{Binding LastDetails, Converter={x:Static ObjectConverters.IsNotNull}}"
                  Margin="8,0,0,0" />
          <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" TextWrapping="Wrap" />
        </DockPanel>
      </Grid>

    </Grid>

    <!-- Calibration details overlay. The dim layer's padding caps the card height at the window,
         so the content sizes to itself and scrolls only when it would not fit. -->
    <Border Background="#B0000000" IsVisible="{Binding IsDetailsOpen}" Padding="40,32">
      <Border Background="#2C2C2C" BorderBrush="#565656" BorderThickness="1" CornerRadius="4" MaxWidth="720" Padding="24,20" HorizontalAlignment="Center" VerticalAlignment="Center">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="Calibration details" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10" />
          <DockPanel DockPanel.Dock="Bottom" LastChildFill="True" Margin="0,10,0,0">
            <Button DockPanel.Dock="Left" Content="Copy debug text" Command="{Binding CopyDetailsCommand}" />
            <Button DockPanel.Dock="Left" Content="Save debug zip..." Command="{Binding SaveDetailsZipCommand}" Margin="8,0,0,0" />
            <Button DockPanel.Dock="Right" Content="Close" MinWidth="72" HorizontalContentAlignment="Center" Command="{Binding CloseDetailsCommand}" />
            <TextBlock Text="{Binding DetailsFeedback}" Foreground="#999999" FontSize="12" VerticalAlignment="Center" Margin="12,0,8,0" TextTrimming="CharacterEllipsis" />
          </DockPanel>
          <ScrollViewer>
            <!-- Right margin keeps the overlay scrollbar from covering the Status column. -->
            <StackPanel Spacing="10" Margin="0,0,16,0">
              <TextBlock Text="{Binding LastDetails.Error}" Foreground="#FF6B6B" TextWrapping="Wrap"
                         IsVisible="{Binding LastDetails.HasError, FallbackValue=False}" />
              <Border Background="#26FFB020" BorderBrush="#FFB020" BorderThickness="1" CornerRadius="4" Padding="12,10"
                      IsVisible="{Binding LastDetails.HasWarnings, FallbackValue=False}">
                <StackPanel Spacing="5">
                  <TextBlock FontWeight="SemiBold" Foreground="#FFC65A" Text="Warnings" />
                  <ItemsControl ItemsSource="{Binding LastDetails.Warnings}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,4" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding LastDetails.FitSummary}" TextWrapping="Wrap" VerticalAlignment="Center" />
                <!-- Hover-only info chip; not a Button because it triggers nothing -->
                <Border Background="#3A3A3A" BorderBrush="#565656" BorderThickness="1" CornerRadius="3"
                        Padding="8,2" Cursor="Help" VerticalAlignment="Center"
                        ToolTip.Tip="{StaticResource DeltaEExplanation}">
                  <Border.Styles>
                    <Style Selector="Border:pointerover">
                      <Setter Property="Background" Value="#454545" />
                    </Style>
                  </Border.Styles>
                  <TextBlock Text="What is dE?" FontSize="11" Foreground="#C8C8C8" />
                </Border>
              </StackPanel>
              <StackPanel Spacing="5">
                <TextBlock FontWeight="SemiBold" Text="Additional corrections" />
                <ItemsControl ItemsSource="{Binding LastDetails.AppliedCorrections}"
                              IsVisible="{Binding LastDetails.HasCorrections, FallbackValue=False}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                      <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,4" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="None - the standard LUT fit covered everything; no capture problems needed special handling." Foreground="#999999" TextWrapping="Wrap"
                           IsVisible="{Binding !LastDetails.HasCorrections, FallbackValue=False}" />
              </StackPanel>

              <!-- Palette check: what the LUT does to each captured color -->
              <Border Background="#232323" CornerRadius="4" Padding="12,10"
                      IsVisible="{Binding LastDetails.HasVisualizations, FallbackValue=False}">
                <StackPanel Spacing="6">
                  <TextBlock FontWeight="SemiBold" FontSize="12" Text="Palette check" />
                  <TextBlock FontSize="11" Foreground="#999999" TextWrapping="Wrap"
                             Text="Each tile: captured (top), corrected by this LUT (middle), target (bottom). dE compares the middle and bottom rows - corrected against target - so a low dE means the middle stripe matches the target, however far off the capture was. Hover for values; an orange border marks fit outliers." />
                  <TextBlock FontSize="11" Foreground="#999999" Text="Neutrals (dark to light)" />
                  <ItemsControl ItemsSource="{Binding LastDetails.NeutralSwatches}"
                                ItemTemplate="{StaticResource SwatchTileTemplate}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <UniformGrid Columns="9" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                  <TextBlock FontSize="11" Foreground="#999999" Text="Colors (worst dE first)" Margin="0,4,0,0" />
                  <ItemsControl ItemsSource="{Binding LastDetails.ChromaSwatches}"
                                ItemTemplate="{StaticResource SwatchTileTemplate}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <UniformGrid Columns="10" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                </StackPanel>
              </Border>

              <!-- Two plot boxes side by side; equal heights via the shared grid row, plots
                   anchored to the bottom so differing caption heights do not misalign them.
                   Star columns: Auto would let the wrapping captions measure unconstrained
                   and push the second box off screen. -->
              <Grid ColumnDefinitions="*,*" ColumnSpacing="10"
                    IsVisible="{Binding LastDetails.HasVisualizations, FallbackValue=False}">

                <!-- Tone curve: fitted transform sampled along the gray axis.
                     Canvas size must match CalibrationDetailsViewModel.CurvePlotSize (220). -->
                <Border Grid.Column="0" Background="#232323" CornerRadius="4" Padding="12,10">
                  <DockPanel>
                    <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" FontSize="12" Text="Tone curve" />
                    <TextBlock DockPanel.Dock="Top" FontSize="11" Foreground="#999999" TextWrapping="Wrap" Margin="0,6,0,6"
                               Text="Per-channel output for gray input (0 to 1, left to right). The dashed diagonal is no correction; flat ends indicate clipping." />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom">
                    <Border Background="#1A1A1A" BorderBrush="#484848" BorderThickness="1"
                            Width="222" Height="222">
                      <Canvas Width="220" Height="220">
                        <!-- quarter gridlines -->
                        <Line StartPoint="55,0" EndPoint="55,220" Stroke="#333333" StrokeThickness="1" />
                        <Line StartPoint="110,0" EndPoint="110,220" Stroke="#333333" StrokeThickness="1" />
                        <Line StartPoint="165,0" EndPoint="165,220" Stroke="#333333" StrokeThickness="1" />
                        <Line StartPoint="0,55" EndPoint="220,55" Stroke="#333333" StrokeThickness="1" />
                        <Line StartPoint="0,110" EndPoint="220,110" Stroke="#333333" StrokeThickness="1" />
                        <Line StartPoint="0,165" EndPoint="220,165" Stroke="#333333" StrokeThickness="1" />
                        <!-- identity reference -->
                        <Line StartPoint="0,220" EndPoint="220,0" Stroke="#777777" StrokeThickness="1" StrokeDashArray="4,4" />
                        <!-- channel curves; blue last so it stays visible where they overlap.
                             FallbackValue: after Reset LastDetails is null and a null Points crashes the renderer. -->
                        <Polyline Points="{Binding LastDetails.CurvePointsR, FallbackValue={x:Static vm:CalibrationDetailsViewModel.EmptyPoints}}" Stroke="#FF6B6B" StrokeThickness="1.5" StrokeJoin="Round" IsVisible="{Binding #CurveToggleR.IsChecked}" />
                        <Polyline Points="{Binding LastDetails.CurvePointsG, FallbackValue={x:Static vm:CalibrationDetailsViewModel.EmptyPoints}}" Stroke="#4EC94E" StrokeThickness="1.5" StrokeJoin="Round" IsVisible="{Binding #CurveToggleG.IsChecked}" />
                        <Polyline Points="{Binding LastDetails.CurvePointsB, FallbackValue={x:Static vm:CalibrationDetailsViewModel.EmptyPoints}}" Stroke="#6BA5FF" StrokeThickness="1.5" StrokeJoin="Round" IsVisible="{Binding #CurveToggleB.IsChecked}" />
                      </Canvas>
                    </Border>
                    <!-- Channel toggles: inspect one curve at a time. Off = struck-through
                         and dimmed label, so the state reads without relying on the theme's
                         subtle checked background. -->
                    <StackPanel Spacing="6" VerticalAlignment="Top">
                      <StackPanel.Styles>
                        <Style Selector="ToggleButton:not(:checked) TextBlock">
                          <Setter Property="TextDecorations" Value="Strikethrough" />
                          <Setter Property="Opacity" Value="0.4" />
                        </Style>
                        <!-- Explicit checked backgrounds: the theme's checked-hover brush is
                             nearly identical to the resting surface, so on hover a checked
                             toggle looked like it lost its state. -->
                        <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                          <Setter Property="Background" Value="#565656" />
                        </Style>
                        <Style Selector="ToggleButton:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                          <Setter Property="Background" Value="#666666" />
                        </Style>
                      </StackPanel.Styles>
                      <ToggleButton x:Name="CurveToggleR" IsChecked="True" MinWidth="44" HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Show or hide the red channel curve">
                        <TextBlock Text="R" Foreground="#FF6B6B" FontWeight="SemiBold" />
                      </ToggleButton>
                      <ToggleButton x:Name="CurveToggleG" IsChecked="True" MinWidth="44" HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Show or hide the green channel curve">
                        <TextBlock Text="G" Foreground="#4EC94E" FontWeight="SemiBold" />
                      </ToggleButton>
                      <ToggleButton x:Name="CurveToggleB" IsChecked="True" MinWidth="44" HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Show or hide the blue channel curve">
                        <TextBlock Text="B" Foreground="#6BA5FF" FontWeight="SemiBold" />
                      </ToggleButton>
                    </StackPanel>
                    </StackPanel>
                  </DockPanel>
                </Border>

                <!-- Vectorscope: Oklab a-b chroma plane, size must match
                     CalibrationDetailsViewModel.ScopePlotSize (220) -->
                <Border Grid.Column="1" Background="#232323" CornerRadius="4" Padding="12,10">
                  <DockPanel>
                    <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" FontSize="12" Text="Color shift" />
                    <TextBlock DockPanel.Dock="Top" FontSize="11" Foreground="#999999" TextWrapping="Wrap" Margin="0,6,0,6"
                               Text="Each capture's hue and saturation (lightness ignored). The line runs from the captured color to the corrected one; the dot is the target. Center is neutral gray; a common twist around the center means a colorspace mismatch." />
                    <Border Background="#1A1A1A" BorderBrush="#484848" BorderThickness="1"
                            Width="222" Height="222" HorizontalAlignment="Left" VerticalAlignment="Bottom">
                      <Panel Width="220" Height="220">
                        <!-- center crosshair + saturation rings -->
                        <Line StartPoint="110,0" EndPoint="110,220" Stroke="#333333" StrokeThickness="1" />
                        <Line StartPoint="0,110" EndPoint="220,110" Stroke="#333333" StrokeThickness="1" />
                        <Ellipse Width="73" Height="73" Stroke="#333333" StrokeThickness="1"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Ellipse Width="147" Height="147" Stroke="#333333" StrokeThickness="1"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <!-- shift lines, observed to corrected; null Data (e.g. after Reset) is safe -->
                        <Path Data="{Binding LastDetails.ScopeShifts}" Stroke="#777777" StrokeThickness="1" />
                        <!-- target dots; diameter must equal 2 * ScopeDotRadius -->
                        <ItemsControl ItemsSource="{Binding LastDetails.ScopeDots}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <Canvas />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.Styles>
                            <!-- items get wrapped in ContentPresenters; Canvas.Left on the
                                 template root would not position them -->
                            <Style Selector="ContentPresenter" x:DataType="vm:CalibrationDetailsViewModel+ScopeDot">
                              <Setter Property="Canvas.Left" Value="{Binding X}" />
                              <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                          </ItemsControl.Styles>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CalibrationDetailsViewModel+ScopeDot">
                              <Ellipse Width="6" Height="6" Fill="{Binding Brush}">
                                <ToolTip.Tip>
                                  <TextBlock Text="{Binding Tooltip}" FontFamily="Consolas,Menlo,DejaVu Sans Mono,monospace" />
                                </ToolTip.Tip>
                              </Ellipse>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Panel>
                    </Border>
                  </DockPanel>
                </Border>
              </Grid>

              <Border Background="#232323" CornerRadius="4" Padding="12,10">
                <StackPanel Spacing="4">
                  <Grid ColumnDefinitions="*,80,80,70,200">
                    <TextBlock Grid.Column="0" Text="Capture" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock Grid.Column="1" Text="Target" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock Grid.Column="2" Text="Observed" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock Grid.Column="3" Text="dE" FontWeight="SemiBold" FontSize="12"
                               ToolTip.Tip="{StaticResource DeltaEExplanation}" />
                    <TextBlock Grid.Column="4" Text="Status" FontWeight="SemiBold" FontSize="12" />
                  </Grid>
                  <ItemsControl ItemsSource="{Binding LastDetails.Rows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:CalibrationDetailsViewModel+DetailRow">
                        <Grid ColumnDefinitions="*,80,80,70,200">
                          <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12" TextTrimming="CharacterEllipsis" />
                          <TextBlock Grid.Column="1" Text="{Binding Target}" FontSize="12" FontFamily="Consolas,Menlo,DejaVu Sans Mono,monospace" />
                          <TextBlock Grid.Column="2" Text="{Binding Observed}" FontSize="12" FontFamily="Consolas,Menlo,DejaVu Sans Mono,monospace" />
                          <TextBlock Grid.Column="3" Text="{Binding DeltaE}" FontSize="12" FontFamily="Consolas,Menlo,DejaVu Sans Mono,monospace" />
                          <TextBlock Grid.Column="4" Text="{Binding Status}" FontSize="12" TextWrapping="Wrap" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Border>

    <!-- Modal warning overlay (used in the browser, where dialog Windows are unavailable) -->
    <Border Background="#B0000000" IsVisible="{Binding Overlay.IsOpen, FallbackValue=False}">
      <Border Background="#2C2C2C" BorderBrush="#565656" BorderThickness="1" CornerRadius="4" MaxWidth="420" Padding="20,16" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="{Binding Overlay.Title}" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Overlay.Message}" TextWrapping="Wrap" MaxWidth="380" />
          <Button Content="OK" MinWidth="72" HorizontalAlignment="Right" HorizontalContentAlignment="Center" Command="{Binding Overlay.DismissCommand}" />
        </StackPanel>
      </Border>
    </Border>

  </Panel>

</UserControl>
