<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AutoLUT.App.ViewModels"
    x:Class="AutoLUT.App.Views.MainView"
    x:DataType="vm:MainWindowViewModel"
    Background="#2C2C2C"
>

  <Panel>

    <Grid ColumnDefinitions="300,*" RowDefinitions="*,Auto">

      <!-- Screenshot list -->
      <Grid Grid.Column="0" Grid.Row="0" RowDefinitions="Auto,*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="*,*" ColumnSpacing="8" Margin="12,12,12,8">
          <Button Grid.Column="0" Content="Load images..." Command="{Binding AddScreenshotsCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
          <Button Grid.Column="1" Content="Reset" Command="{Binding ResetCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
        </Grid>
        <ListBox Grid.Row="1" Margin="12,0,12,8" Background="#232323" ItemsSource="{Binding Screenshots}" SelectedItem="{Binding SelectedScreenshot}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:ScreenshotItemViewModel">
              <Grid ColumnDefinitions="Auto,*">
                <Border
                    Grid.Column="0"
                    Width="16"
                    Height="16"
                    Margin="0,2,8,0"
                    VerticalAlignment="Top"
                    CornerRadius="3"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Background="{Binding SwatchBrush}"
                    IsVisible="{Binding SwatchBrush, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                  <TextBlock Foreground="{Binding StatusBrush}" FontSize="11" TextWrapping="Wrap"><Run Text="{Binding StatusPrefix}" /><Run Text="{Binding StatusHex}" FontFamily="Consolas,Menlo,DejaVu Sans Mono,monospace" /><Run Text="{Binding StatusSuffix}" /></TextBlock>
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="8" Margin="12,0,12,12">
          <Button Grid.Column="0" Content="Generate LUT" Command="{Binding GenerateCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
          <Button Grid.Column="1" Content="Save LUT.png" Command="{Binding SaveLutCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
        </Grid>
      </Grid>

      <!-- Preview -->
      <Border Grid.Column="1" Grid.Row="0" Background="#151515" BorderBrush="#484848" BorderThickness="1" Margin="0,12,12,12" CornerRadius="4">
        <Panel>
          <TextBlock Text="No screenshot selected" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding PreviewImage, Converter={x:Static ObjectConverters.IsNull}}" />
          <Image Source="{Binding PreviewImage}" Stretch="Uniform" Margin="8" />
        </Panel>
      </Border>

      <!-- Bottom bar: show-corrected under the list, status aligned to the column split, actions on the right -->
      <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="300,*" Margin="0,0,12,12">
        <CheckBox Grid.Column="0" Content="Show Corrected Image" IsChecked="{Binding ShowCorrected}" IsEnabled="{Binding HasLut}" VerticalAlignment="Center" Margin="12,0,0,0" />
        <DockPanel Grid.Column="1" LastChildFill="True">
          <Button DockPanel.Dock="Right"
                  Content="How to use"
                  Command="{Binding OpenHelpCommand}"
                  Margin="8,0,0,0" />
          <Button DockPanel.Dock="Right"
                  Content="Check for updates"
                  Command="{Binding CheckForUpdatesCommand}"
                  IsVisible="{Binding IsDesktop}"
                  Margin="8,0,0,0" />
          <Button DockPanel.Dock="Right"
                  Content="Download savestates"
                  IsVisible="{Binding ShowSavestatesLink}"
                  Margin="8,0,0,0">
            <Button.Flyout>
              <Flyout>
                <StackPanel Spacing="4" MinWidth="160">
                  <Button Content="gz 0.3.7 OoT 1.0" Tag="1.0" Click="OnSavestatesVersionClick"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                  <Button Content="gz 0.3.7 OoT 1.1" IsEnabled="False" ToolTip.Tip="Not made yet"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                  <Button Content="gz 0.3.7 OoT 1.2" Tag="1.2" Click="OnSavestatesVersionClick"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                </StackPanel>
              </Flyout>
            </Button.Flyout>
          </Button>
          <Button DockPanel.Dock="Right"
                  Content="Show details"
                  Command="{Binding OpenDetailsCommand}"
                  IsVisible="{Binding LastDetails, Converter={x:Static ObjectConverters.IsNotNull}}"
                  Margin="8,0,0,0" />
          <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" TextWrapping="Wrap" />
        </DockPanel>
      </Grid>

    </Grid>

    <!-- Help overlay -->
    <Border Background="#B0000000" IsVisible="{Binding IsHelpOpen}">
      <Border Background="#2C2C2C" BorderBrush="#565656" BorderThickness="1" CornerRadius="4" MaxWidth="640" Padding="24,20" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="10">
          <TextBlock Text="How to use AutoLUT" FontWeight="SemiBold" FontSize="16" />
          <Border Background="#26FFB020" BorderBrush="#FFB020" BorderThickness="1" CornerRadius="4" Padding="12,10">
            <StackPanel Spacing="5">
              <TextBlock FontWeight="SemiBold" Foreground="#FFC65A" Text="OBS setup - do this first" />
              <TextBlock TextWrapping="Wrap" Text="In Settings, Advanced, Video set Color Space to Rec. 709 and Color Range to Limited, since this is what modern streaming sites expect. In your capture source's Properties, set Color Space to Rec. 601 if that option exists, since this is the color space the Wii and N64 output." />
              <TextBlock TextWrapping="Wrap" Foreground="#C8C8C8" Text="Exception: a scaler or internal HDMI mod (RetroTINK, PixelFX, Retro GEM, and similar) has already converted the signal to Rec. 709, so leave the source at Rec. 709 - actual hardware HDMI mods only; passive adapters like Wii2HDMI do not convert color space and stay at Rec. 601." />
              <TextBlock TextWrapping="Wrap" Foreground="#C8C8C8" Text="Mismatched color space settings distort colors before AutoLUT ever sees them." />
            </StackPanel>
          </Border>
          <TextBlock TextWrapping="Wrap" Text="{Binding HelpSavestatesStep}" />
          <TextBlock TextWrapping="Wrap" Text="2. Load each savestate in gz and screenshot the solid color it displays - 39 colors, any order, any filenames. Screenshot the raw capture source: in OBS, right-click the source and use Screenshot (Source) with no filters. Strongly recommended: bind a hotkey to Screenshot Selected Source (OBS Settings, Hotkeys) - 39 screenshots through the right-click menu is a good way to lose your mind." />
          <TextBlock TextWrapping="Wrap" Text="3. Click Load Images and select all your captures, then Generate LUT." />
          <TextBlock TextWrapping="Wrap" Text="4. Check the result with Show Corrected Image - the preview matches exactly what OBS will render." />
          <TextBlock TextWrapping="Wrap" Text="5. Save LUT.png, then in OBS: right-click your capture source, Filters, add Apply LUT, and select the file." />
          <TextBlock TextWrapping="Wrap" Foreground="#999999" Text="All 9 gray savestates (including black and white) are required; at least 20 of the 39 colors must be identified. The game HUD in the screenshots is fine - just keep the center of the screen clear." />
          <DockPanel LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="Full instructions on GitHub" Click="OnReadmeLinkClick" />
            <Button DockPanel.Dock="Right" Content="Close" MinWidth="72" HorizontalContentAlignment="Center" Command="{Binding CloseHelpCommand}" />
          </DockPanel>
        </StackPanel>
      </Border>
    </Border>

    <!-- Calibration details overlay. The dim layer's padding caps the card height at the window,
         so the content sizes to itself and scrolls only when it would not fit. -->
    <Border Background="#B0000000" IsVisible="{Binding IsDetailsOpen}" Padding="40,32">
      <Border Background="#2C2C2C" BorderBrush="#565656" BorderThickness="1" CornerRadius="4" MaxWidth="720" Padding="24,20" HorizontalAlignment="Center" VerticalAlignment="Center">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="Calibration details" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10" />
          <DockPanel DockPanel.Dock="Bottom" LastChildFill="True" Margin="0,10,0,0">
            <Button DockPanel.Dock="Left" Content="Copy debug text" Command="{Binding CopyDetailsCommand}" />
            <Button DockPanel.Dock="Left" Content="Save debug zip..." Command="{Binding SaveDetailsZipCommand}" Margin="8,0,0,0" />
            <Button DockPanel.Dock="Right" Content="Close" MinWidth="72" HorizontalContentAlignment="Center" Command="{Binding CloseDetailsCommand}" />
            <TextBlock Text="{Binding DetailsFeedback}" Foreground="#999999" FontSize="12" VerticalAlignment="Center" Margin="12,0,8,0" TextTrimming="CharacterEllipsis" />
          </DockPanel>
          <ScrollViewer>
            <!-- Right margin keeps the overlay scrollbar from covering the Status column. -->
            <StackPanel Spacing="10" Margin="0,0,16,0">
              <TextBlock Text="{Binding LastDetails.Error}" Foreground="#FF6B6B" TextWrapping="Wrap"
                         IsVisible="{Binding LastDetails.HasError, FallbackValue=False}" />
              <Border Background="#26FFB020" BorderBrush="#FFB020" BorderThickness="1" CornerRadius="4" Padding="12,10"
                      IsVisible="{Binding LastDetails.HasWarnings, FallbackValue=False}">
                <StackPanel Spacing="5">
                  <TextBlock FontWeight="SemiBold" Foreground="#FFC65A" Text="Warnings" />
                  <ItemsControl ItemsSource="{Binding LastDetails.Warnings}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,4" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
              <TextBlock Text="{Binding LastDetails.FitSummary}" TextWrapping="Wrap" />
              <StackPanel Spacing="5">
                <TextBlock FontWeight="SemiBold" Text="Additional corrections" />
                <ItemsControl ItemsSource="{Binding LastDetails.AppliedCorrections}"
                              IsVisible="{Binding LastDetails.HasCorrections, FallbackValue=False}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                      <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,4" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="None - the standard LUT fit covered everything; no capture problems needed special handling." Foreground="#999999" TextWrapping="Wrap"
                           IsVisible="{Binding !LastDetails.HasCorrections, FallbackValue=False}" />
              </StackPanel>
              <Border Background="#232323" CornerRadius="4" Padding="12,10">
                <StackPanel Spacing="4">
                  <Grid ColumnDefinitions="*,80,80,70,200">
                    <TextBlock Grid.Column="0" Text="Capture" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock Grid.Column="1" Text="Target" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock Grid.Column="2" Text="Observed" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock Grid.Column="3" Text="dE" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock Grid.Column="4" Text="Status" FontWeight="SemiBold" FontSize="12" />
                  </Grid>
                  <ItemsControl ItemsSource="{Binding LastDetails.Rows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:CalibrationDetailsViewModel+DetailRow">
                        <Grid ColumnDefinitions="*,80,80,70,200">
                          <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12" TextTrimming="CharacterEllipsis" />
                          <TextBlock Grid.Column="1" Text="{Binding Target}" FontSize="12" FontFamily="Consolas,Menlo,DejaVu Sans Mono,monospace" />
                          <TextBlock Grid.Column="2" Text="{Binding Observed}" FontSize="12" FontFamily="Consolas,Menlo,DejaVu Sans Mono,monospace" />
                          <TextBlock Grid.Column="3" Text="{Binding DeltaE}" FontSize="12" FontFamily="Consolas,Menlo,DejaVu Sans Mono,monospace" />
                          <TextBlock Grid.Column="4" Text="{Binding Status}" FontSize="12" TextWrapping="Wrap" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Border>

    <!-- Modal warning overlay (used in the browser, where dialog Windows are unavailable) -->
    <Border Background="#B0000000" IsVisible="{Binding Overlay.IsOpen, FallbackValue=False}">
      <Border Background="#2C2C2C" BorderBrush="#565656" BorderThickness="1" CornerRadius="4" MaxWidth="420" Padding="20,16" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="{Binding Overlay.Title}" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Overlay.Message}" TextWrapping="Wrap" MaxWidth="380" />
          <Button Content="OK" MinWidth="72" HorizontalAlignment="Right" HorizontalContentAlignment="Center" Command="{Binding Overlay.DismissCommand}" />
        </StackPanel>
      </Border>
    </Border>

  </Panel>

</UserControl>
